---
import BaseLayout from "@components/base/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getAllThemes } from "@lib/themeConfig";

const title = "网站设置";
const description = "自定义您的网站偏好设置";

const themes = getAllThemes();
---

<BaseLayout title={title} description={description}>
  <div class="container mx-auto max-w-4xl px-4 py-8">
    <div class="glass rounded-lg p-6 md:p-8">
      <h1 class="mb-8 text-3xl font-bold text-txt-p dark:text-darkmode-txt-p">
        {title}
      </h1>

      <div class="space-y-8">
        <section class="rounded-lg border border-border bg-bg-t p-6 dark:border-darkmode-border dark:bg-darkmode-bg-t">
          <h2 class="mb-4 text-xl font-semibold text-txt-p dark:text-darkmode-txt-p">
            主题设置
          </h2>
          <p class="mb-4 text-txt-s dark:text-darkmode-txt-s">
            选择您喜欢的网站主题，主题将立即应用到整个网站。
          </p>
          
          <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
            {themes.map((theme) => (
              <button
                data-theme-setting={theme.name}
                class="theme-setting-btn flex items-center gap-4 rounded-lg border-2 border-border bg-bg-t p-4 text-left transition-all hover:border-txt-p dark:border-darkmode-border dark:hover:border-darkmode-txt-p"
                onclick={`setThemeSetting('${theme.name}')`}
              >
                <span class="text-3xl">{theme.icon}</span>
                <div>
                  <div class="font-semibold text-txt-p dark:text-darkmode-txt-p">
                    {theme.label}
                  </div>
                  <div class="text-sm text-txt-s dark:text-darkmode-txt-s">
                    {theme.isDark ? '暗黑模式' : '明亮模式'}
                  </div>
                </div>
              </button>
            ))}
          </div>
        </section>

        <section class="rounded-lg border border-border bg-bg-t p-6 dark:border-darkmode-border dark:bg-darkmode-bg-t">
          <h2 class="mb-4 text-xl font-semibold text-txt-p dark:text-darkmode-txt-p">
            默认主题设置
          </h2>
          <p class="mb-4 text-txt-s dark:text-darkmode-txt-s">
            设置网站的默认主题，新访客将看到此主题。
          </p>
          
          <select
            id="default-theme-select"
            class="w-full rounded-lg border border-border bg-bg-t px-4 py-2 text-txt-s outline-none focus:border-txt-p focus:ring-1 focus:ring-txt-p dark:border-darkmode-border dark:bg-darkmode-bg-t dark:text-darkmode-txt-s dark:focus:border-darkmode-txt-p dark:focus:ring-darkmode-txt-p"
            onchange="setDefaultTheme(this.value)"
          >
            {themes.map((theme) => (
              <option value={theme.name}>
                {theme.label}
              </option>
            ))}
          </select>
          
          <div class="mt-4 flex items-center gap-2">
            <button
              onclick="saveDefaultTheme()"
              class="rounded-lg bg-txt-p px-4 py-2 text-white transition-all hover:opacity-90 dark:bg-darkmode-txt-p"
            >
              保存设置
            </button>
            <span id="save-message" class="hidden text-green-600">
              ✓ 设置已保存
            </span>
          </div>
        </section>

        <section class="rounded-lg border border-border bg-bg-t p-6 dark:border-darkmode-border dark:bg-darkmode-bg-t">
          <h2 class="mb-4 text-xl font-semibold text-txt-p dark:text-darkmode-txt-p">
            主题预览
          </h2>
          <p class="mb-4 text-txt-s dark:text-darkmode-txt-s">
            当前应用的主题效果预览。
          </p>
          
          <div class="space-y-3">
            <div class="rounded-lg border border-border bg-bg-t p-4 dark:border-darkmode-border dark:bg-darkmode-bg-t">
              <h3 class="mb-2 text-lg font-semibold text-txt-p dark:text-darkmode-txt-p">
                卡片样式示例
              </h3>
              <p class="text-txt-s dark:text-darkmode-txt-s">
                这是一个示例卡片，展示了当前主题的背景色、文字颜色和边框样式。
              </p>
              <button class="mt-3 rounded bg-txt-p px-4 py-2 text-white dark:bg-darkmode-txt-p">
                按钮示例
              </button>
            </div>
          </div>
        </section>
      </div>
    </div>
  </div>

  <script is:inline>
    function setThemeSetting(themeName) {
      // 移除所有主题类
      document.documentElement.classList.remove('default', 'dark', 'forest', 'sunset');
      
      // 添加当前主题类
      document.documentElement.classList.add(themeName);
      
      // 处理暗黑模式
      if (themeName === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      // 保存主题到本地存储
      localStorage.setItem('currentTheme', themeName);
      
      // 更新按钮选中状态
      updateThemeButtonStates(themeName);
      
      // 更新默认主题选择器
      document.getElementById('default-theme-select').value = themeName;
    }
    
    function updateThemeButtonStates(activeTheme) {
      const buttons = document.querySelectorAll('.theme-setting-btn');
      buttons.forEach(btn => {
        const themeName = btn.getAttribute('data-theme-setting');
        if (themeName === activeTheme) {
          btn.classList.add('border-txt-p', 'ring-2', 'ring-txt-p');
          btn.classList.remove('border-border');
        } else {
          btn.classList.remove('border-txt-p', 'ring-2', 'ring-txt-p');
          btn.classList.add('border-border');
        }
      });
    }
    
    function setDefaultTheme(themeName) {
      console.log('设置默认主题:', themeName);
    }
    
    function saveDefaultTheme() {
      const defaultTheme = document.getElementById('default-theme-select').value;
      localStorage.setItem('defaultTheme', defaultTheme);
      
      // 清除用户当前选择的主题，使其使用默认主题
      localStorage.removeItem('currentTheme');
      
      // 应用默认主题
      setThemeSetting(defaultTheme);
      
      // 显示保存成功消息
      const message = document.getElementById('save-message');
      message.classList.remove('hidden');
      setTimeout(() => {
        message.classList.add('hidden');
      }, 2000);
    }
    
    // 初始化
    document.addEventListener('DOMContentLoaded', () => {
      const currentTheme = localStorage.getItem('currentTheme') || localStorage.getItem('defaultTheme') || 'default';
      setThemeSetting(currentTheme);
      
      const defaultTheme = localStorage.getItem('defaultTheme') || 'default';
      document.getElementById('default-theme-select').value = defaultTheme;
    });
  </script>
</BaseLayout>