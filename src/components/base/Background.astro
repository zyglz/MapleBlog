<!-- Theme-based Background -->
<style>
  html::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: -1;
    transition: all 0.5s ease-in-out;
    pointer-events: none;
    background-image: url(/src/assets/backgrounds/macos2.jpg);
  }

  /* 暗黑主题背景 */
  html.dark::before {
    background-image: linear-gradient(rgba(71, 71, 71, 0.9), rgba(0, 0, 0, 0.2)), url(/src/assets/backgrounds/macos2-night.jpg);
  }

  /* 森林主题背景 */
  html.forest::before {
    background-image: linear-gradient(rgba(40, 167, 69, 0.1), rgba(40, 167, 69, 0.2)), url(/src/assets/backgrounds/bwca-day.jpg);
  }

  /* 日落主题背景 */
  html.sunset::before {
    background-image: linear-gradient(rgba(253, 126, 20, 0.1), rgba(253, 126, 20, 0.2)), url(/src/assets/backgrounds/bwca-day.jpg);
  }
</style>


