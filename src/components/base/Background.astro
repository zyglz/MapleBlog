<!-- Theme-based Background -->
<style>
  html::before {
    content: "";
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: -1;
    transition: all 0.5s ease-in-out;
    pointer-events: none;
    background-image: url(/src/assets/backgrounds/macos2.jpg);
  }

  /* 暗黑主题背景 */
  html.dark::before {
    background-image: url(/src/assets/backgrounds/macos2-night.jpg);
  }

  /* 森林主题背景 */
  html.forest::before {
    background-image: linear-gradient(rgba(40, 167, 69, 0.1), rgba(40, 167, 69, 0.2)), url(/src/assets/backgrounds/bwca-day.jpg);
  }

  /* 日落主题背景 */
  html.sunset::before {
    background-image: linear-gradient(rgba(253, 126, 20, 0.1), rgba(253, 126, 20, 0.2)), url(/src/assets/backgrounds/bwca-day.jpg);
  }
</style>

<script is:inline>
  // 在页面加载前设置正确的主题背景，避免闪烁
  (function() {
    // 获取当前主题
    function getCurrentTheme() {
      const userTheme = localStorage.getItem("currentTheme");
      if (userTheme) {
        return userTheme;
      }
      
      const defaultTheme = localStorage.getItem("defaultTheme");
      if (defaultTheme) {
        return defaultTheme;
      }
      
      return "forest";
    }

    const currentTheme = getCurrentTheme();
    
    // 在DOM加载前设置正确的主题类
    if (document.documentElement) {
      document.documentElement.classList.add(currentTheme);
      
      // 处理暗黑模式
      if (currentTheme === "dark") {
        document.documentElement.classList.add("dark");
      }
    }
  })();
</script>
