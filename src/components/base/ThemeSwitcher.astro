---
import ThemeScript from "@components/base/ThemeScript.astro";
---

<div class="flex items-center">
  <select
    id="theme-selector"
    class="rounded-lg border border-border bg-bg-t px-3 py-1.5 text-sm text-txt-s outline-none transition-all duration-300 hover:border-txt-p focus:border-txt-p focus:ring-1 focus:ring-txt-p dark:border-darkmode-border dark:bg-darkmode-bg-t dark:text-darkmode-txt-s dark:hover:border-darkmode-txt-p dark:focus:border-darkmode-txt-p dark:focus:ring-darkmode-txt-p"
  >
    <option value="default">默认主题</option>
    <option value="dark">暗黑主题</option>
    <option value="forest">森林主题</option>
    <option value="sunset">日落主题</option>
  </select>
</div>

<ThemeScript />
