<script is:inline data-astro-rerun>
  // 主题配置
  const themes = {
    default: {
      name: 'default',
      label: '默认主题',
      isDark: false
    },
    dark: {
      name: 'dark',
      label: '暗黑主题',
      isDark: true
    },
    forest: {
      name: 'forest',
      label: '森林主题',
      isDark: false
    },
    sunset: {
      name: 'sunset',
      label: '日落主题',
      isDark: false
    }
  };

  // 主题循环顺序
  const themeOrder = ['default', 'dark', 'forest', 'sunset'];

  // 获取当前主题
  function getCurrentTheme() {
    return localStorage.getItem('currentTheme') || 'default';
  }

  // 获取下一个主题
  function getNextTheme(currentTheme) {
    const currentIndex = themeOrder.indexOf(currentTheme);
    const nextIndex = (currentIndex + 1) % themeOrder.length;
    return themeOrder[nextIndex];
  }

  // 设置主题
  function setTheme(themeName) {
    // 移除所有主题类
    document.documentElement.classList.remove(...Object.keys(themes));
    
    // 添加当前主题类
    document.documentElement.classList.add(themeName);
    
    // 处理暗黑模式
    if (themes[themeName].isDark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    
    // 保存主题到本地存储
    localStorage.setItem('currentTheme', themeName);
    
    // 更新主题状态显示
    updateThemeDisplay(themeName);
  }

  // 更新主题显示
  function updateThemeDisplay(themeName) {
    // 这里可以添加主题名称显示逻辑
    console.log('当前主题:', themes[themeName].label);
  }

  // 初始化主题
  function initTheme() {
    const themeName = getCurrentTheme();
    setTheme(themeName);
  }

  // 初始化
  initTheme();

  // 监听页面加载
  document.addEventListener("astro:page-load", () => {
    initTheme();
    
    // 主题切换器事件
    const themeSwitch = document.querySelectorAll("[data-theme-switcher]");
    themeSwitch.forEach((el) => {
      el.addEventListener("click", () => {
        const currentTheme = getCurrentTheme();
        const nextTheme = getNextTheme(currentTheme);
        setTheme(nextTheme);
      });
    });
  });
</script>
