<script is:inline data-astro-rerun>
  // 从环境变量获取默认主题，默认为 'default'
  const configDefaultTheme = import.meta.env.PUBLIC_DEFAULT_THEME || 'default';

  // 主题配置
  const themes = {
    default: {
      name: 'default',
      label: '默认主题',
      icon: '🌐',
      isDark: false
    },
    dark: {
      name: 'dark',
      label: '暗黑主题',
      icon: '🌙',
      isDark: true
    },
    forest: {
      name: 'forest',
      label: '森林主题',
      icon: '🌲',
      isDark: false
    },
    sunset: {
      name: 'sunset',
      label: '日落主题',
      icon: '🌅',
      isDark: false
    }
  };

  // 获取当前主题
  function getCurrentTheme() {
    // 优先使用用户选择的主题
    const userTheme = localStorage.getItem('currentTheme');
    if (userTheme) {
      return userTheme;
    }
    
    // 其次使用默认主题设置
    const defaultTheme = localStorage.getItem('defaultTheme');
    if (defaultTheme) {
      return defaultTheme;
    }
    
    // 最后使用系统默认主题
    return configDefaultTheme;
  }

  // 设置主题
  function setTheme(themeName) {
    // 移除所有主题类
    document.documentElement.classList.remove(...Object.keys(themes));
    
    // 添加当前主题类
    document.documentElement.classList.add(themeName);
    
    // 处理暗黑模式
    if (themes[themeName].isDark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
    
    // 保存主题到本地存储
    localStorage.setItem('currentTheme', themeName);
    
    // 更新主题图标显示
    updateThemeIcon(themeName);
    
    // 隐藏下拉菜单
    hideThemeDropdown();
  }

  // 更新主题图标
  function updateThemeIcon(themeName) {
    const iconElement = document.getElementById('current-theme-icon');
    if (iconElement) {
      iconElement.textContent = themes[themeName].icon;
    }
  }

  // 显示主题下拉菜单
  function showThemeDropdown() {
    const dropdown = document.getElementById('theme-selector-dropdown');
    if (dropdown) {
      dropdown.classList.remove('hidden');
    }
  }

  // 隐藏主题下拉菜单
  function hideThemeDropdown() {
    const dropdown = document.getElementById('theme-selector-dropdown');
    if (dropdown) {
      dropdown.classList.add('hidden');
    }
  }

  // 初始化主题
  function initTheme() {
    const themeName = getCurrentTheme();
    setTheme(themeName);
  }

  // 绑定事件监听器
  function bindEventListeners() {
    // 主题选择器按钮点击事件
    const selectorBtn = document.getElementById('theme-selector-btn');
    if (selectorBtn) {
      selectorBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        const dropdown = document.getElementById('theme-selector-dropdown');
        if (dropdown) {
          if (dropdown.classList.contains('hidden')) {
            showThemeDropdown();
          } else {
            hideThemeDropdown();
          }
        }
      });
    }

    // 主题选项点击事件
    const themeOptions = document.querySelectorAll('.theme-option');
    themeOptions.forEach((option) => {
      option.addEventListener('click', (e) => {
        e.stopPropagation();
        const themeName = option.getAttribute('data-theme');
        if (themeName) {
          setTheme(themeName);
        }
      });
    });

    // 点击其他地方关闭下拉菜单
    document.addEventListener('click', (e) => {
      const dropdown = document.getElementById('theme-selector-dropdown');
      const selectorBtn = document.getElementById('theme-selector-btn');
      if (dropdown && !dropdown.contains(e.target) && !selectorBtn.contains(e.target)) {
        hideThemeDropdown();
      }
    });
  }

  // 初始化
  initTheme();

  // 监听DOM加载完成
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindEventListeners);
  } else {
    bindEventListeners();
  }

  // 监听页面加载
  document.addEventListener("astro:page-load", () => {
    initTheme();
    bindEventListeners();
  });
</script>
